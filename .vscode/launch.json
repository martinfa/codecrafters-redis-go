{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Test: Current File",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": ["-test.v"],
      "showLog": true
    },
    {
      "name": "Debug Test: TestHandleXadd",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/app",
      "args": ["-test.v", "-test.run", "^TestHandleXadd$"],
      "showLog": true
    },
    {
      "name": "Debug Test: Pick Test Name",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/app",
      "args": [
        "-test.v",
        "-test.run",
        "${input:testName}"
      ],
      "showLog": true
    },
    {
      "name": "Debug All Tests (app/)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/app",
      "args": ["-test.v"],
      "showLog": true
    },
    {
      "name": "Debug Redis Server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/app/main.go",
      "showLog": true
    }
  ],
  "inputs": [
    {
      "id": "testName",
      "type": "promptString",
      "description": "Go test name or regex (e.g. TestHandleXadd or TestHandleXadd/xadd_auto_generates)",
      "default": "TestHandleXadd"
    }
  ]
}
